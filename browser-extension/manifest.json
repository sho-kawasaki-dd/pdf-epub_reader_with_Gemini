{
  "manifest_version": 3,
  "name": "Gem Read Browser Extension",
  "version": "1.0.0",
  "description": "Browser extension for translation and analysis using Gemini API.",
  "action": {
    "default_popup": "index.html"
  },
  "commands": {
    "gem-read-phase3-open-overlay": {
      "suggested_key": {
        "default": "Ctrl+Shift+8",
        "mac": "Command+Shift+8"
      },
      "description": "Reopen the Gem Read overlay"
    },
    "gem-read-phase3-add-selection": {
      "suggested_key": {
        "default": "Ctrl+Shift+9",
        "mac": "Command+Shift+9"
      },
      "description": "Add the current text selection to the Gem Read batch"
    },
    "gem-read-phase2-start-rectangle": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Start Gem Read rectangle selection"
    }
  },
  "permissions": [
    "contextMenus",
    "activeTab",
    "offscreen",
    "scripting",
    "storage"
  ],
  "host_permissions": ["http://127.0.0.1/*", "http://localhost/*"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.ts"]
    }
  ],
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  }
}
